#!/usr/bin/env bash
# theme-set — Apply a theme across all applications.
#
# Usage:
#   theme-set <theme-name>        Apply a curated theme (catppuccin-mocha, tokyonight, ...)
#   theme-set -w <wallpaper>      Generate theme from wallpaper using matugen
#
# Curated themes live in ~/.config/theme/themes/<name>/ with per-app config files.
# Wallpaper mode uses matugen to fill ~/.config/theme/templates/ and outputs to current/.
# All app configs import from ~/.config/theme/current/.

set -euo pipefail

THEME_DIR="$HOME/.config/theme"
THEMES_DIR="$THEME_DIR/themes"
TEMPLATES_DIR="$THEME_DIR/templates"
CURRENT_DIR="$THEME_DIR/current"

usage() {
  echo "Usage:"
  echo "  theme-set <theme-name>      Apply a curated theme"
  echo "  theme-set -w <wallpaper>    Generate theme from wallpaper image"
  echo ""
  echo "Run 'theme-list' to see available themes."
  exit 1
}

reload_apps() {
  # waybar: SIGUSR2 forces full config + style reload
  killall -SIGUSR2 waybar   2>/dev/null || true
  # mako: reload notification config
  makoctl reload            2>/dev/null || true
  # btop: reload theme
  killall -SIGUSR2 btop     2>/dev/null || true
  # hyprland: reload to pick up new border colors
  hyprctl reload            2>/dev/null || true
  # swayosd: restart to pick up new styles
  killall swayosd-server    2>/dev/null || true
  sleep 0.3
  uwsm-app -- swayosd-server &>/dev/null &
  # ghostty: reload config (ghostty watches config files automatically)
}

# ── Wallpaper mode ───────────────────────────────────────────────────────────
apply_wallpaper() {
  local wallpaper="$1"

  if [[ ! -f "$wallpaper" ]]; then
    echo "Error: wallpaper '$wallpaper' not found"
    exit 1
  fi

  if ! command -v matugen &>/dev/null; then
    echo "Error: matugen is not installed. Install it with: paru -S matugen-bin"
    exit 1
  fi

  mkdir -p "$CURRENT_DIR"

  # Run matugen — reads ~/.config/matugen/config.toml for template → output mappings
  # Outputs go directly to ~/.config/theme/current/
  matugen image "$wallpaper" \
    --mode dark \
    --type scheme-tonal-spot \
    --prefer saturation

  # Set wallpaper via hyprctl (hyprpaper)
  local monitor
  monitor=$(hyprctl monitors -j | jq -r '.[0].name')
  hyprctl hyprpaper preload "$wallpaper"  2>/dev/null || true
  hyprctl hyprpaper wallpaper "$monitor,$wallpaper" 2>/dev/null || true

  echo "wallpaper:$wallpaper" > "$THEME_DIR/current.name"
  echo "Theme generated from wallpaper: $wallpaper"
  reload_apps
}

# ── Curated theme mode ───────────────────────────────────────────────────────
apply_theme() {
  local theme_name="$1"
  local source_dir="$THEMES_DIR/$theme_name"

  if [[ ! -d "$source_dir" ]]; then
    echo "Error: theme '$theme_name' not found in $THEMES_DIR"
    echo "Available themes:"
    theme-list
    exit 1
  fi

  mkdir -p "$CURRENT_DIR"

  # Copy all theme files into current/
  for file in "$source_dir"/*; do
    [[ -f "$file" ]] || continue
    local filename
    filename=$(basename "$file")
    cp "$file" "$CURRENT_DIR/$filename"
  done

  # ── Special handlers for apps that can't import from current/ ──────────

  # btop: needs theme in its own themes directory
  if [[ -f "$CURRENT_DIR/btop.theme" ]]; then
    local btop_theme
    btop_theme=$(cat "$CURRENT_DIR/btop.theme")
    # btop.theme contains just the theme name — btop ships with catppuccin etc.
    if [[ -n "$btop_theme" ]]; then
      mkdir -p "$HOME/.config/btop"
      # Update btop.conf color_theme line if it exists, or note for user
      if [[ -f "$HOME/.config/btop/btop.conf" ]]; then
        sed -i "s|^color_theme = .*|color_theme = \"$btop_theme\"|" "$HOME/.config/btop/btop.conf"
      fi
    fi
  fi

  # nvim: colorscheme name for the user's neovim config
  # (nvim.txt contains just the colorscheme name, e.g. "catppuccin")

  # GTK: prefer dark/light based on theme
  if command -v gsettings &>/dev/null; then
    if [[ -f "$source_dir/light.mode" ]]; then
      gsettings set org.gnome.desktop.interface color-scheme "prefer-light" 2>/dev/null || true
    else
      gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"  2>/dev/null || true
    fi
  fi

  # Set wallpaper if theme includes one
  if [[ -f "$source_dir/wallpaper.jpg" ]] || [[ -f "$source_dir/wallpaper.png" ]]; then
    local wallpaper
    wallpaper=$(ls "$source_dir"/wallpaper.* 2>/dev/null | head -1)
    local monitor
    monitor=$(hyprctl monitors -j | jq -r '.[0].name')
    hyprctl hyprpaper preload "$wallpaper"  2>/dev/null || true
    hyprctl hyprpaper wallpaper "$monitor,$wallpaper" 2>/dev/null || true
  fi

  echo "$theme_name" > "$THEME_DIR/current.name"
  echo "Theme '$theme_name' applied."
  reload_apps
}

# ── Main ─────────────────────────────────────────────────────────────────────
[[ $# -ge 1 ]] || usage

case "$1" in
  -w|--wallpaper)
    [[ -n "${2:-}" ]] || usage
    apply_wallpaper "$2"
    ;;
  -h|--help)
    usage
    ;;
  *)
    apply_theme "$1"
    ;;
esac
