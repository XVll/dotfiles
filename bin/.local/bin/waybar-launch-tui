#!/usr/bin/env bash
# waybar-launch-tui <app> — launch a TUI in a floating terminal window.
# If the app is already running, focus it instead of opening a duplicate.
# Uses xdg-terminal-exec --app-id for window matching (terminal-agnostic).

APP="$1"
[[ -z "$APP" ]] && exit 1

CLASS="tui.$(basename "$APP")"

# Focus existing window if one is open
if hyprctl clients -j | jq -e ".[] | select(.class == \"$CLASS\")" >/dev/null 2>&1; then
  hyprctl dispatch focuswindow "class:$CLASS"
else
  setsid uwsm-app -- xdg-terminal-exec --app-id="$CLASS" -e "$APP" &
fi
