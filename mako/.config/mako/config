# mako — Wayland notification daemon config

# Layout
width=360
height=110
margin=10
padding=12,16
border-size=1
border-radius=8

# Typography
font=JetBrainsMono Nerd Font 11

# Behavior
default-timeout=5000
ignore-timeout=0
max-visible=5
sort=-time

# Icons
icon-path=/usr/share/icons/Yaru
max-icon-size=48

# Theme colors — generated by theme-set, included here
include=~/.config/theme/current/mako.conf

[urgency=high]
border-size=2
default-timeout=0
